    print("  • MinIO (S3-compatible storage)")
    print()

    print(f"{Colors.YELLOW}Quick Start:{Colors.RESET}")
    print(f"  {Colors.GREEN}python3 flumen init{Colors.RESET}              # Initialize everything")
    print(f"  {Colors.GREEN}python3 flumen summary{Colors.RESET}           # View environment info")
    print(f"  {Colors.GREEN}python3 flumen health{Colors.RESET}            # Check services")
    print()

    print(f"{Colors.YELLOW}Common Commands:{Colors.RESET}")
    print(f"  {Colors.BLUE}Service Management:{Colors.RESET}")
    print("    python3 flumen up --tier 0         # Start foundation services")
    print("    python3 flumen down                # Stop all services")
    print("    python3 flumen ps                  # Show status")
    print()
    print(f"  {Colors.BLUE}Development:{Colors.RESET}")
    print("    python3 flumen shell-pyspark       # Open PySpark shell")
    print("    python3 flumen logs --service spark-master")
