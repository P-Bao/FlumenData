    print(f"{Colors.BLUE}Welcome to FlumenData CLI!{Colors.RESET}")
    print()
    print("FlumenData is an open-source lakehouse platform combining:")
    print("  • Delta Lake (table format)")
    print("  • Apache Spark (compute)")
