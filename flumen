    print(f"{Colors.BLUE}Ready to get started?{Colors.RESET}")
    print(f"  Run: {Colors.GREEN}python3 flumen init{Colors.RESET}")
    print()


def main():
    """Main entry point for FlumenData CLI"""
    parser = create_parser()
    args = parser.parse_args()

    # If no command provided, show friendly welcome
    if not args.command:
        show_welcome()
        return 0

    try:
        # Handle commands
        if args.command == 'help':
            parser.print_help()

        elif args.command == 'init':
            handle_init(args)

        elif args.command == 'init-dirs':
            load_env_file()
            init_data_dirs()

        elif args.command == 'config':
            load_env_file()
            generator = SERVICE_GENERATORS[args.service]
            generator()

        elif args.command == 'up':
            up_services(tier=args.tier, services=args.services)

        elif args.command == 'down':
            down_services()

        elif args.command == 'restart':
            restart_services()

        elif args.command == 'logs':
            show_logs(tier=args.tier, service=args.service, follow=not args.no_follow)

        elif args.command in ['ps', 'status']:
            show_status()

        elif args.command == 'health':
            if args.tier is not None:
                check_tier_health(args.tier)
            else:
                check_all_health()

        elif args.command == 'summary':
            show_summary()

        # Shell commands
        elif args.command == 'shell-postgres':
            shell_postgres()

        elif args.command == 'shell-spark':
            shell_spark()

        elif args.command == 'shell-pyspark':
            shell_pyspark()

        elif args.command == 'shell-spark-sql':
            shell_spark_sql()

        elif args.command == 'shell-mc':
            shell_minio_client()

        # Verification commands
        elif args.command == 'verify-hive':
            verify_hive()

        # Service-specific commands
        elif args.command == 'token-jupyterlab':
            get_jupyterlab_token()

        elif args.command == 'superset-db':
            init_superset_db()

        # Test commands
        elif args.command == 'test':
            if args.integration:
                test_integration()
            elif args.tier is not None:
                test_tier(args.tier)
            else:
                test_all()

        # Cleanup commands
        elif args.command == 'cleanup':
            if args.tier is not None:
                cleanup_tier(args.tier)
            else:
                cleanup_all()

        elif args.command == 'clean':
            clean_environment(force=args.force)

        # Maintenance commands
        elif args.command == 'rebuild':
            rebuild_images()

        elif args.command == 'prune':
            prune_docker()

        else:
            parser.print_help()
            return 1

        return 0

    except KeyboardInterrupt:
        print(f"\n{Colors.YELLOW}Operation cancelled by user{Colors.RESET}")
        return 130
    except Exception as e:
        print(f"{Colors.RED}✗ Error: {e}{Colors.RESET}")
        import traceback
        traceback.print_exc()
        return 1


if __name__ == "__main__":
    sys.exit(main())
