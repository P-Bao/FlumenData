COMPOSE_PROJECT_NAME=flumendata

# Data Directory (configurable - use absolute or relative paths)
# This is where all persistent data will be stored
# Notebooks directory can be a separate git repo!
#
# RECOMMENDED: Use relative path (portable across machines)
DATA_DIR=../flumendata-data
#
# OR use absolute paths (WSL/Windows examples):
#   DATA_DIR=/mnt/d/data-projects    # Windows D: drive (accessible from Windows Explorer)
#   DATA_DIR=/mnt/e/flumendata       # Windows E: drive
#   DATA_DIR=/mnt/c/Users/YourName/flumendata  # Windows C: drive
#   DATA_DIR=~/flumendata-data       # Linux home directory
#   DATA_DIR=/home/user/flumendata   # Linux absolute path

# Postgres
POSTGRES_USER=flumen
POSTGRES_PASSWORD=flumen_pass
POSTGRES_DB=flumendata
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
MINIO_PORT_API=9000
MINIO_PORT_CONSOLE=9001
MINIO_STORAGE_BUCKET=storage

# MinIO S3 endpoints (for internal Docker network communication)
MINIO_SERVER_URL=http://minio:9000
MINIO_BUCKET=lakehouse

# Spark - Versions
SCALA_BINARY_VERSION=2.13
DELTA_VERSION=4.0.0
POSTGRESQL_JDBC_VERSION=42.7.4
HADOOP_AWS_VERSION=3.3.6
AWS_SDK_BUNDLE_VERSION=1.12.772
JAXB_API_VERSION=2.3.1
HIVE_VERSION=4.0.1

# Spark - Resources (adjust based on your machine)
# For 8GB RAM machine: WORKER_MEMORY=2g, WORKER_CORES=2
# For 16GB RAM machine: WORKER_MEMORY=4g, WORKER_CORES=4
# For 32GB RAM machine: WORKER_MEMORY=8g, WORKER_CORES=4
SPARK_WORKER_MEMORY=8g
SPARK_WORKER_CORES=2
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
SPARK_EXECUTOR_CORES=2

# Hive Metastore
HIVE_METASTORE_URI=thrift://hive-metastore:9083

# Lakehouse Databases (2-level: database.table)
LAKEHOUSE_DATABASES=flumendata

# Trino
TRINO_PORT=8082
TRINO_VERSION=450
TRINO_ENVIRONMENT=lakehouse

# Superset
SUPERSET_VERSION=5.0.0
SUPERSET_PORT=8088
SUPERSET_DB_NAME=superset
SUPERSET_SECRET_KEY=flumen_superset_secret
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin123
SUPERSET_ADMIN_FIRST_NAME=Superset
SUPERSET_ADMIN_LAST_NAME=Admin
SUPERSET_ADMIN_EMAIL=admin@flumen.local
