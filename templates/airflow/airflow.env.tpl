AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__ENABLE_XCOM_PICKLING=True
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__FERNET_KEY=${AIRFLOW_FERNET_KEY}
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${AIRFLOW_DB_NAME}
AIRFLOW__DATABASE__LOAD_DEFAULT_CONNECTIONS=False
AIRFLOW__DATABASE__SQL_ENGINE_ENCODING=utf-8
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080
AIRFLOW__WEBSERVER__SECRET_KEY=${AIRFLOW_SECRET_KEY}
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:${AIRFLOW_PORT}
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=True
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__DEFAULT_TIMEZONE=UTC
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_STANDALONE_ADMIN_USERNAME=${AIRFLOW_ADMIN_USERNAME}
AIRFLOW_STANDALONE_ADMIN_PASSWORD=${AIRFLOW_ADMIN_PASSWORD}
AIRFLOW_STANDALONE_ADMIN_EMAIL=${AIRFLOW_ADMIN_EMAIL}
AIRFLOW_STANDALONE_ADMIN_FIRSTNAME=${AIRFLOW_ADMIN_FIRST_NAME}
AIRFLOW_STANDALONE_ADMIN_LASTNAME=${AIRFLOW_ADMIN_LAST_NAME}
