COMPOSE_PROJECT_NAME=flumendata

# Postgres
POSTGRES_USER=flumen
POSTGRES_PASSWORD=flumen_pass
POSTGRES_DB=flumendata
POSTGRES_PORT=5432

# Valkey
VALKEY_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
MINIO_PORT_API=9000
MINIO_PORT_CONSOLE=9001

# Spark
SCALA_BINARY_VERSION=2.13
DELTA_VERSION=4.0.0
POSTGRESQL_JDBC_VERSION=42.7.4
HADOOP_AWS_VERSION=3.3.6
AWS_SDK_BUNDLE_VERSION=1.12.772
JAXB_API_VERSION=2.3.1
HIVE_VERSION=4.0.1

# MinIO 
MINIO_SERVER_URL=http://minio:9000
MINIO_BUCKET=lakehouse

# Hive Metastore
HIVE_METASTORE_URI=thrift://hive-metastore:9083

# Apache Atlas
ATLAS_URL=http://atlas:21000
ATLAS_USER=admin
ATLAS_PASSWORD=admin

# Lakehouse Databases (2-level: database.table)
LAKEHOUSE_DATABASES=flumendata

# dbt
DBT_TARGET_SCHEMA=analytics
DBT_THREADS=4
DBT_CORE_VERSION=1.7.14
DBT_ADAPTERS=dbt-postgres==1.7.14

# MLflow
MLFLOW_PORT=5000
MLFLOW_ARTIFACT_PATH=mlflow
MLFLOW_VERSION=2.14.1

# Trino
TRINO_PORT=8082
TRINO_VERSION=450
TRINO_ENVIRONMENT=lakehouse

# Superset
SUPERSET_VERSION=5.0.0
SUPERSET_PORT=8088
SUPERSET_DB_NAME=superset
SUPERSET_SECRET_KEY=flumen_superset_secret
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin123
SUPERSET_ADMIN_FIRST_NAME=Superset
SUPERSET_ADMIN_LAST_NAME=Admin
SUPERSET_ADMIN_EMAIL=admin@flumen.local

# Airflow
AIRFLOW_VERSION=2.10.2
AIRFLOW_PORT=8085
AIRFLOW_DB_NAME=airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_ADMIN_FIRST_NAME=Airflow
AIRFLOW_ADMIN_LAST_NAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@flumen.local
AIRFLOW_FERNET_KEY=dXNlLWFjdHVhbC1mZXJuZXQta2V5LWhlcmUtbGF0ZXIh
AIRFLOW_SECRET_KEY=flumen_airflow_secret
